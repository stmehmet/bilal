# Generate a unique secret: openssl rand -hex 32
SECRET_KEY=changeme-in-production

# Optional: dead-man's-switch ping URL (uptime monitoring).
# The scheduler pings this on every successful adhan playback, so if a unit
# wedges or stops reaching its speakers the pings stop and you get alerted.
# Create a free check at https://healthchecks.io (one per Pi), set a period of
# ~12h and grace of ~30h, and paste its ping URL here. Works with ntfy or any
# webhook too. Leave blank to disable.
HEALTHCHECK_PING_URL=
